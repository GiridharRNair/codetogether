        "@tailwindcss/vite": "^4.3.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.17.0",
        "monaco-editor": "^0.55.1",
        "next-themes": "^0.4.6",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-router": "^7.16.0",
        "shadcn": "^4.10.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
